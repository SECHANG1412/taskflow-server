# .env (보안상 이 파일은 .gitignore 에 추가하는 것이 좋습니다!)

# PostgreSQL 설정
# 주의: host 를 'localhost' 가 아닌 docker-compose.yml 에 정의된 서비스 이름('db')으로 지정!
DATABASE_URL=postgresql+asyncpg://fastapi_user:your_strong_password@db:5432/fastapi_db
POSTGRES_USER=fastapi_user
POSTGRES_PASSWORD=your_strong_password # 실제 강력한 비밀번호 사용!
POSTGRES_DB=fastapi_db

# FastAPI 앱 설정
# 터미널에서 'openssl rand -hex 32' 로 강력한 키 생성하여 대체하세요!
SECRET_KEY=replace_with_your_actual_32_byte_secret_key # 반드시 변경!
ACCESS_TOKEN_EXPIRE_MINUTES=30